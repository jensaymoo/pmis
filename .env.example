# PostgreSQL
POSTGRES_USER=pmis
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pmis
POSTGRES_PORT=5432

# PostgREST
POSTGREST_PORT=3000

# Swagger UI (просмотр OpenAPI-схемы PostgREST)
SWAGGER_PORT=8080

# Секрет подписи JWT. Сама GUC app.jwt_secret на стороне БД настраивается
# миграцией 006_jwt_secret (Фаза 2); PostgREST использует эту переменную
# напрямую уже сейчас для старта. Не менее 32 случайных символов:
# openssl rand -base64 32
PGRST_JWT_SECRET=change_me_to_a_long_random_secret
